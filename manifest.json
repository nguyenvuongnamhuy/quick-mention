{
  "manifest_version": 3,
  "name": "Quick Mention",
  "version": "1.0.0",
  "description": "Automatically expands shortcut keywords into blue mention chips in Google Chat.",
  "content_scripts": [
    {
      "matches": [
        "https://chat.google.com/*",
        "https://mail.google.com/chat/*"
      ],
      "js": [
        "src/csv-parser.js",
        "src/app-state.js",
        "src/sheet-loader.js",
        "src/webhook-loader.js",
        "src/label-loader.js",
        "src/chat-dom.js",
        "src/webhook.js",
        "src/app.js",
        "config.js",
        "index.js"
      ],
      "all_frames": true,
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  },
  "host_permissions": [
    "https://docs.google.com/spreadsheets/*",
    "https://chat.google.com/*",
    "https://mail.google.com/*"
  ]
}